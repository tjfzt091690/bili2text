DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bilibili

LOG_DIR=./log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

VIDEO_BASE_DIR=bilibili_video
DOWNLOAD_INTERVAL_MIN=5
DOWNLOAD_INTERVAL_MAX=15
AUDIO_CONV_DIR=audio/conv
AUDIO_SLICE_DIR=audio/slice
OUTPUT_DIR=outputs

SLICE_LENGTH_MS=45000
AUDIO_CODEC=libmp3lame
WAV_SAMPLE_RATE=16000
WAV_CHANNELS=1

WHISPER_MODEL=tiny
WHISPER_DEFAULT_PROMPT=以下是普通话的句子。

PARAFORMER_MODEL=iic/speech_paraformer-large-vad-punc_asr_nat-zh-cn-16k-common-vocab8404-pytorch
PARAFORMER_MODEL_REVISION=v2.0.4

XUNFEI_APPID=
XUNFEI_SECRET_KEY=
XUNFEI_LFASR_HOST=https://raasr.xfyun.cn/v2/api
XUNFEI_UPLOAD_DURATION=200
XUNFEI_RESULT_TYPE=transfer,predict
XUNFEI_POLL_INTERVAL=5

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False
FLASK_MAX_CONTENT_LENGTH=524288000